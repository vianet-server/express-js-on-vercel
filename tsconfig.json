{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "moduleDetection": "force",
    "types": ["node"],
    "outDir": "./dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false
  },
  "exclude": ["vianet"]
}
